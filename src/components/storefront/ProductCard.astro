---
interface Props {
  product: {
    id: string;
    name: string;
    slug: string;
    price: number;
    compare_at_price?: number;
    images: string[];
    stock: number;
    featured?: boolean;
    tags?: string[];
  };
}

const { product } = Astro.props;
const img1 = product.images?.[0] || '';
const img2 = product.images?.[1] || '';
const isOnSale = product.compare_at_price && product.compare_at_price > product.price;
const isOutOfStock = product.stock === 0;
const discount = isOnSale ? Math.round((1 - product.price / product.compare_at_price!) * 100) : 0;
---

<a href={`/tienda/${product.slug}`} class="product-card-link">
  <!-- Image area — 4:5 portrait, clean white bg -->
  <div class="product-card-img-wrap">
    <!-- Placeholder gradient when no image -->
    {!img1 && (
      <div style="width:100%;height:100%;background:linear-gradient(145deg,#f0ede8,#ddd8c8);display:flex;align-items:center;justify-content:center;">
        <svg width="40" height="40" fill="none" viewBox="0 0 24 24" stroke="#c4bfb4" stroke-width="1">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
      </div>
    )}

    {img1 && (
      <img
        src={img1}
        alt={product.name}
        class={`product-img product-img-primary${img2 ? ' has-second' : ''}`}
        loading="lazy"
      />
    )}

    {img2 && (
      <img
        src={img2}
        alt={`${product.name} — vista`}
        class="product-img product-img-secondary"
        loading="lazy"
      />
    )}

    <!-- Out of stock -->
    {isOutOfStock && (
      <div class="product-badge-oos">Agotado</div>
    )}

    <!-- Sale -->
    {isOnSale && !isOutOfStock && (
      <div class="product-badge-sale">-{discount}%</div>
    )}
  </div>

  <!-- Text -->
  <div class="product-card-info">
    <h3 class="product-card-name">{product.name}</h3>
    {product.tags && product.tags.length > 0 && (
      <p class="product-card-tag">{product.tags[0]}</p>
    )}
    <div class="product-card-price">
      <span class="price-main">{product.price.toFixed(2)} €</span>
      {isOnSale && (
        <span class="price-compare">{product.compare_at_price!.toFixed(2)} €</span>
      )}
    </div>
  </div>
</a>

<style>
  .product-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .product-card-img-wrap {
    position: relative;
    overflow: hidden;
    background: #FFFFFF;
    aspect-ratio: 4/5;
    border: 1px solid #DDD8C8;
    box-shadow: 0 2px 8px rgba(37,37,37,0.05);
    transition: box-shadow 0.3s ease;
  }

  .product-card-link:hover .product-card-img-wrap {
    box-shadow: 0 6px 24px rgba(37,37,37,0.10);
    border-color: #c8c4b4;
  }

  .product-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity 0.6s ease, transform 0.6s ease;
  }

  /* Primary: slight scale on hover when no second image */
  .product-img-primary:not(.has-second) {
    transform: scale(1);
  }
  .product-card-link:hover .product-img-primary:not(.has-second) {
    transform: scale(1.03);
  }

  /* Hover swap when two images */
  .product-img-primary.has-second { opacity: 1; }
  .product-card-link:hover .product-img-primary.has-second { opacity: 0; }

  .product-img-secondary { opacity: 0; }
  .product-card-link:hover .product-img-secondary { opacity: 1; }

  /* Badges */
  .product-badge-oos {
    position: absolute;
    inset: 0;
    background: rgba(255,255,255,0.55);
    backdrop-filter: blur(2px);
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Quattrocento Sans', sans-serif;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #716A56;
    border: 1px solid #DDD8C8;
    margin: 12px;
  }

  .product-badge-sale {
    position: absolute;
    top: 10px;
    left: 10px;
    background: #3F5147;
    color: #fff;
    font-family: 'Quattrocento Sans', sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 8px;
  }

  /* Card text */
  .product-card-info {
    padding: 10px 2px 0;
  }

  .product-card-name {
    font-family: 'Quattrocento Sans', 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: #252525;
    margin: 0 0 3px;
    line-height: 1.4;
    transition: color 0.15s;
  }
  .product-card-link:hover .product-card-name {
    color: #3F5147;
  }

  .product-card-tag {
    font-size: 11px;
    color: #9E9589;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin: 0 0 4px;
  }

  .product-card-price {
    display: flex;
    align-items: baseline;
    gap: 6px;
  }

  .price-main {
    font-family: 'Quattrocento Sans', sans-serif;
    font-size: 13px;
    font-weight: 700;
    color: #252525;
  }

  .price-compare {
    font-size: 12px;
    color: #9E9589;
    text-decoration: line-through;
  }
</style>

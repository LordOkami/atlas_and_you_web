---
import StoreLayout from '../../layouts/StoreLayout.astro';
import { getCollections } from '../../lib/api';

const collections = await getCollections();

const capitalize = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
---

<StoreLayout title="Colecciones — Atlas&You" description="Explora todas las colecciones de joyería artesanal de Atlas&You. Pendientes, colgantes y pulseras de arcilla polimérica y resina.">

  <!-- Hero banner -->
  <section style="position:relative;overflow:hidden;height:280px;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#3F5147;">
    <div style="position:absolute;inset:0;background:linear-gradient(135deg,#3F5147 0%,#2C3B31 60%,#1e2a21 100%);"></div>
    <!-- Subtle texture overlay -->
    <div style="position:absolute;inset:0;opacity:0.06;background-image:radial-gradient(circle,#fff 1px,transparent 1px);background-size:24px 24px;"></div>
    <div style="position:relative;z-index:1;text-align:center;padding:0 24px;">
      <p style="font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#c7875a;margin:0 0 12px;">Atlas&amp;You</p>
      <h1 style="font-family:'Playfair Display',Georgia,serif;font-weight:700;font-size:clamp(2.2rem,5vw,3.8rem);color:#FAFAF8;margin:0 0 14px;line-height:1.05;">
        Colecciones
      </h1>
      <p style="font-family:'Nunito',sans-serif;font-size:14px;color:rgba(250,250,248,0.75);margin:0;max-width:420px;">
        Cada colección cuenta una historia — piezas únicas hechas a mano con amor.
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <div style="max-width:1440px;margin:0 auto;padding:18px 24px 0;">
    <nav style="font-size:12px;color:#888;">
      <a href="/" style="color:#888;text-decoration:none;" onmouseenter="this.style.color='#3F5147'" onmouseleave="this.style.color='#888'">Inicio</a>
      <span style="margin:0 6px;color:#ccc;">›</span>
      <span style="color:#252525;font-weight:700;">Colecciones</span>
    </nav>
  </div>

  <!-- Collections grid -->
  <div style="max-width:1440px;margin:0 auto;padding:32px 24px 80px;">

    {collections.length === 0 ? (
      <div style="text-align:center;padding:100px 32px;">
        <p style="font-family:'Playfair Display',Georgia,serif;font-weight:400;font-size:1.8rem;color:#888;margin:0 0 10px;">Próximamente</p>
        <p style="font-size:13px;color:#aaa;margin:0 0 28px;">Estamos preparando nuestras colecciones. ¡Vuelve pronto!</p>
        <a href="/tienda" style="font-size:12px;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;color:#3F5147;text-decoration:none;border-bottom:2px solid #3F5147;padding-bottom:2px;">
          Ver toda la tienda
        </a>
      </div>
    ) : (
      <div class="collections-grid">
        {collections.map((col) => (
          <a href={`/colecciones/${col.slug}`} class="collection-card">
            <!-- Cover image -->
            <div class="collection-card-img">
              {col.image_url ? (
                <img
                  src={col.image_url}
                  alt={`Colección ${capitalize(col.name)}`}
                  style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform 0.5s ease;"
                  class="collection-cover-img"
                  loading="lazy"
                />
              ) : (
                <div style="position:absolute;inset:0;background:linear-gradient(135deg,#c7875a 0%,#d4a07a 40%,#e8c4a0 100%);display:flex;align-items:center;justify-content:center;">
                  <svg width="48" height="48" fill="none" viewBox="0 0 24 24" stroke="rgba(255,255,255,0.5)" stroke-width="1">
                    <circle cx="12" cy="12" r="10"/><path d="M2 12h20"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                  </svg>
                </div>
              )}
              <!-- Dark gradient overlay at bottom -->
              <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(37,37,37,0.65) 0%,transparent 55%);pointer-events:none;"></div>
              <!-- Product count badge -->
              <div style="position:absolute;top:14px;right:14px;background:rgba(0,0,0,0.45);color:#fff;font-family:'Nunito',sans-serif;font-size:10px;font-weight:800;letter-spacing:0.08em;text-transform:uppercase;padding:4px 10px;backdrop-filter:blur(4px);">
                {col.product_count} {col.product_count === 1 ? 'pieza' : 'piezas'}
              </div>
            </div>

            <!-- Card text -->
            <div style="padding:18px 20px 20px;">
              <p style="font-family:'Nunito',sans-serif;font-size:10px;font-weight:800;letter-spacing:0.15em;text-transform:uppercase;color:#c7875a;margin:0 0 6px;">Colección</p>
              <h2 style="font-family:'Playfair Display',Georgia,serif;font-weight:700;font-size:1.35rem;color:#252525;margin:0 0 8px;line-height:1.2;">
                {capitalize(col.name)}
              </h2>
              {col.description && (
                <p style="font-family:'Nunito',sans-serif;font-size:13px;color:#716A56;line-height:1.65;margin:0 0 14px;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">
                  {col.description}
                </p>
              )}
              <span style="font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;color:#3F5147;display:inline-flex;align-items:center;gap:5px;">
                Explorar
                <svg width="12" height="12" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </span>
            </div>
          </a>
        ))}
      </div>
    )}

  </div>

</StoreLayout>

<style>
  .collections-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  @media (max-width: 1100px) {
    .collections-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 600px) {
    .collections-grid { grid-template-columns: 1fr; gap: 16px; }
  }

  .collection-card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: #fff;
    border: 1px solid #e8e4dc;
    transition: box-shadow 0.2s ease, transform 0.2s ease;
  }
  .collection-card:hover {
    box-shadow: 0 12px 40px rgba(63,81,71,0.14);
    transform: translateY(-2px);
  }
  .collection-card:hover .collection-cover-img {
    transform: scale(1.04);
  }

  .collection-card-img {
    position: relative;
    overflow: hidden;
    aspect-ratio: 4/3;
    background: #f0ebe3;
  }
</style>

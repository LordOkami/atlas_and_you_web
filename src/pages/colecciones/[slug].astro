---
import StoreLayout from '../../layouts/StoreLayout.astro';
import ProductCard from '../../components/storefront/ProductCard.astro';
import { getCollections, getProducts } from '../../lib/api';

const { slug } = Astro.params;

const collections = await getCollections();
const collection = collections.find((c) => c.slug === slug);

if (!collection) return Astro.redirect('/colecciones');

const productsRaw = await getProducts({ collection: slug });
const products = productsRaw.map((p) => ({
  ...p,
  price: parseFloat(p.price),
  compare_at_price: p.compare_at_price ? parseFloat(p.compare_at_price) : undefined,
}));

const capitalize = (s: string) => s.charAt(0).toUpperCase() + s.slice(1);
const heroBackground = collection.image_url
  ? `url('${collection.image_url}')`
  : 'linear-gradient(135deg, #3F5147, #5a7a61)';
const hasHeroImage = !!collection.image_url;
---

<StoreLayout
  title={`Colección ${capitalize(collection.name)} — Atlas&You`}
  description={collection.description || `Explora la colección ${capitalize(collection.name)} de Atlas&You — joyería artesanal hecha a mano.`}
>

  <!-- Hero -->
  <section style={`position:relative;overflow:hidden;min-height:360px;display:flex;flex-direction:column;align-items:center;justify-content:center;background:#3F5147;`}>
    {hasHeroImage && (
      <img
        src={collection.image_url!}
        alt={`Colección ${capitalize(collection.name)}`}
        style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;"
      />
    )}
    {!hasHeroImage && (
      <div style={`position:absolute;inset:0;background:${heroBackground};`}></div>
    )}
    <!-- Overlay -->
    <div style={`position:absolute;inset:0;background:${hasHeroImage ? 'rgba(0,0,0,0.48)' : 'rgba(0,0,0,0.25)'};`}></div>
    <div style="position:relative;z-index:1;text-align:center;padding:48px 24px;">
      <p style="font-family:'Nunito',sans-serif;font-size:11px;font-weight:800;letter-spacing:0.2em;text-transform:uppercase;color:#c7875a;margin:0 0 10px;">Colección</p>
      <h1 style="font-family:'Playfair Display',Georgia,serif;font-weight:700;font-size:clamp(2.2rem,5vw,4rem);color:#FAFAF8;margin:0 0 16px;line-height:1.05;">
        {capitalize(collection.name)}
      </h1>
      {collection.description && (
        <p style="font-family:'Nunito',sans-serif;font-size:15px;color:rgba(250,250,248,0.85);max-width:520px;margin:0 auto 20px;line-height:1.7;">
          {collection.description}
        </p>
      )}
      <p style="font-family:'Nunito',sans-serif;font-size:12px;font-weight:700;color:rgba(250,250,248,0.65);letter-spacing:0.08em;text-transform:uppercase;margin:0;">
        {products.length} {products.length === 1 ? 'pieza' : 'piezas'}
      </p>
    </div>
  </section>

  <!-- Breadcrumb + controls bar -->
  <div style="background:#fff;border-bottom:1px solid #e8e8e8;position:sticky;top:0;z-index:20;">
    <div style="max-width:1440px;margin:0 auto;padding:12px 24px;display:flex;align-items:center;justify-content:space-between;gap:16px;flex-wrap:wrap;">
      <!-- Breadcrumb -->
      <nav style="font-size:12px;color:#888;display:flex;align-items:center;gap:0;">
        <a href="/" style="color:#888;text-decoration:none;" onmouseenter="this.style.color='#3F5147'" onmouseleave="this.style.color='#888'">Inicio</a>
        <span style="margin:0 6px;color:#ccc;">›</span>
        <a href="/colecciones" style="color:#888;text-decoration:none;" onmouseenter="this.style.color='#3F5147'" onmouseleave="this.style.color='#888'">Colecciones</a>
        <span style="margin:0 6px;color:#ccc;">›</span>
        <span style="color:#c7875a;font-weight:700;">{capitalize(collection.name)}</span>
      </nav>
      <!-- Count + back link -->
      <div style="display:flex;align-items:center;gap:16px;">
        <span style="font-size:12px;color:#aaa;">{products.length} {products.length === 1 ? 'pieza' : 'piezas'}</span>
        <a href="/colecciones" style="font-size:12px;font-weight:700;letter-spacing:0.06em;color:#3F5147;text-decoration:none;white-space:nowrap;border-bottom:1px solid #3F5147;" onmouseenter="this.style.color='#c7875a';this.style.borderBottomColor='#c7875a'" onmouseleave="this.style.color='#3F5147';this.style.borderBottomColor='#3F5147'">
          ← Todas las colecciones
        </a>
      </div>
    </div>
  </div>

  <!-- Product grid -->
  <div style="max-width:1440px;margin:0 auto;padding:32px 24px 80px;">
    {products.length > 0 ? (
      <div class="collection-product-grid">
        {products.map((product) => <ProductCard product={product} />)}
      </div>
    ) : (
      <div style="text-align:center;padding:100px 32px;">
        <p style="font-family:'Playfair Display',Georgia,serif;font-weight:400;font-size:1.8rem;color:#888;margin:0 0 10px;">Esta colección está vacía</p>
        <p style="font-size:13px;color:#aaa;margin:0 0 28px;">Próximamente habrá nuevas piezas en esta colección.</p>
        <a href="/tienda" style="font-size:12px;font-weight:800;letter-spacing:0.1em;text-transform:uppercase;color:#3F5147;text-decoration:none;border-bottom:2px solid #3F5147;padding-bottom:2px;">
          Ver toda la tienda
        </a>
      </div>
    )}
  </div>

</StoreLayout>

<style>
  .collection-product-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 16px;
  }
  @media (max-width: 1100px) {
    .collection-product-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 700px) {
    .collection-product-grid { grid-template-columns: repeat(2, 1fr); gap: 10px; }
  }
</style>

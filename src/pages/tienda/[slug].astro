---
import StoreLayout from '../../layouts/StoreLayout.astro';
import ProductCard from '../../components/storefront/ProductCard.astro';
import { getDb, IS_MOCK } from '../../lib/firebase-admin';
import { mockProducts } from '../../lib/mock-data';

const { slug } = Astro.params;
let product: any = null;
let related: any[] = [];

if (IS_MOCK) {
  product = mockProducts.find(p => p.slug === slug && p.active) || null;
  if (product) related = mockProducts.filter(p => p.category_id === product.category_id && p.id !== product.id && p.active).slice(0,4);
} else {
  const db = getDb();
  const snap = await db.collection('products').where('slug','==',slug).where('active','==',true).limit(1).get();
  if (!snap.empty) {
    const doc = snap.docs[0];
    product = { id: doc.id, ...doc.data() };
    if (product.category_id) {
      const catDoc = await db.collection('categories').doc(product.category_id).get();
      if (catDoc.exists) product.categories = { id: catDoc.id, ...catDoc.data() };
    }
    const relSnap = await db.collection('products').where('category_id','==',product.category_id).where('active','==',true).limit(5).get();
    related = relSnap.docs.map(d => ({ id: d.id, ...d.data() })).filter((p: any) => p.id !== product.id).slice(0,4);
  }
}

if (!product) return Astro.redirect('/tienda');

const isOnSale = product.compare_at_price && product.compare_at_price > product.price;
const discount = isOnSale ? Math.round((1 - product.price / product.compare_at_price) * 100) : 0;
const isOutOfStock = product.stock === 0;
const isLowStock = product.stock > 0 && product.stock <= 3;
---

<StoreLayout title={`${product.name} — Atlas&You`} description={product.description}>

  <div style="max-width:1440px;margin:0 auto;padding:40px 32px 80px;">

    <!-- Breadcrumb -->
    <nav style="display:flex;align-items:center;gap:8px;font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#9E9589;margin-bottom:48px;">
      <a href="/" style="color:#9E9589;text-decoration:none;" onmouseenter="this.style.color='#252525'" onmouseleave="this.style.color='#9E9589'">Inicio</a>
      <span style="color:#DDD8C8;">/</span>
      <a href="/tienda" style="color:#9E9589;text-decoration:none;" onmouseenter="this.style.color='#252525'" onmouseleave="this.style.color='#9E9589'">Tienda</a>
      {product.categories && (
        <>
          <span style="color:#DDD8C8;">/</span>
          <a href={`/tienda?categoria=${product.categories.slug}`} style="color:#9E9589;text-decoration:none;" onmouseenter="this.style.color='#252525'" onmouseleave="this.style.color='#9E9589'">{product.categories.name}</a>
        </>
      )}
      <span style="color:#DDD8C8;">/</span>
      <span style="color:#252525;">{product.name}</span>
    </nav>

    <!-- Main layout -->
    <div class="product-layout">

      <!-- Gallery -->
      <div>
        <!-- Main image -->
        <div style="aspect-ratio:4/5;overflow:hidden;background:#FFFFFF;border:1px solid #DDD8C8;box-shadow:0 2px 16px rgba(37,37,37,0.06);">
          <img id="main-image"
            src={product.images?.[0] || ''}
            alt={product.name}
            style="width:100%;height:100%;object-fit:cover;transition:opacity 0.25s;"
          />
        </div>

        <!-- Thumbnails -->
        {product.images && product.images.length > 1 && (
          <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:8px;">
            {product.images.map((img: string, i: number) => (
              <button class="thumb-btn"
                style={`aspect-ratio:1;overflow:hidden;background:#fff;border:1.5px solid ${i === 0 ? '#3F5147' : '#DDD8C8'};cursor:pointer;padding:0;transition:border-color 0.15s;`}
                data-src={img} data-index={i}
              >
                <img src={img} alt={`${product.name} ${i+1}`} style="width:100%;height:100%;object-fit:cover;display:block;" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Info -->
      <div>
        <!-- Category + sale -->
        <div style="display:flex;align-items:center;gap:10px;margin-bottom:10px;">
          {product.categories && (
            <a href={`/tienda?categoria=${product.categories.slug}`}
              style="font-size:11px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:#3F5147;text-decoration:none;">
              {product.categories.name}
            </a>
          )}
          {isOnSale && (
            <span style="background:#3F5147;color:#fff;font-size:10px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;padding:2px 8px;">-{discount}%</span>
          )}
        </div>

        <!-- Name -->
        <h1 style="font-family:'Trirong',Georgia,serif;font-weight:300;font-size:clamp(1.8rem,3.5vw,2.8rem);color:#252525;margin:0 0 20px;line-height:1.15;">
          {product.name}
        </h1>

        <!-- Price -->
        <div style="display:flex;align-items:baseline;gap:12px;margin-bottom:6px;">
          <span style="font-size:1.5rem;font-weight:700;color:#252525;">{product.price.toFixed(2)} €</span>
          {isOnSale && (
            <span style="font-size:1.1rem;color:#9E9589;text-decoration:line-through;">{product.compare_at_price.toFixed(2)} €</span>
          )}
        </div>
        <p style="font-size:11px;color:#9E9589;letter-spacing:0.05em;margin-bottom:24px;">IVA incluido · Envío calculado al finalizar</p>

        <!-- Stock alerts -->
        {isOutOfStock && (
          <div style="display:flex;align-items:center;gap:8px;padding:12px 16px;background:#f5f3ef;border:1px solid #DDD8C8;margin-bottom:20px;">
            <span style="width:6px;height:6px;border-radius:50%;background:#9E9589;flex-shrink:0;"></span>
            <p style="font-size:13px;color:#716A56;font-weight:700;margin:0;">Agotado — escríbenos para consultar disponibilidad</p>
          </div>
        )}
        {isLowStock && (
          <div style="display:flex;align-items:center;gap:8px;padding:12px 16px;background:#eef2ee;border:1px solid #c4d4c6;margin-bottom:20px;">
            <span style="width:6px;height:6px;border-radius:50%;background:#3F5147;flex-shrink:0;"></span>
            <p style="font-size:13px;color:#3F5147;font-weight:700;margin:0;">Solo quedan {product.stock} unidades</p>
          </div>
        )}

        <!-- Description -->
        <div style="border-top:1px solid #DDD8C8;border-bottom:1px solid #DDD8C8;padding:20px 0;margin-bottom:24px;">
          <p style="font-size:14px;color:#716A56;line-height:1.75;margin:0;">{product.description}</p>
        </div>

        <!-- Tags -->
        {product.tags && product.tags.length > 0 && (
          <div style="display:flex;flex-wrap:wrap;gap:6px;margin-bottom:24px;">
            {product.tags.map((tag: string) => (
              <span style="font-size:10px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#716A56;border:1px solid #DDD8C8;padding:4px 10px;">{tag}</span>
            ))}
          </div>
        )}

        <!-- Add to cart -->
        <button
          id="add-to-cart"
          disabled={isOutOfStock}
          data-product={JSON.stringify({ id:product.id, name:product.name, price:product.price, image:product.images?.[0]||'', slug:product.slug, stock:product.stock })}
          style={`width:100%;padding:15px 32px;font-size:12px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;font-family:'Quattrocento Sans',sans-serif;border:none;cursor:${isOutOfStock?'not-allowed':'pointer'};transition:background 0.2s;${isOutOfStock ? 'background:#DDD8C8;color:#9E9589;' : 'background:#3F5147;color:#FAFAF8;'}`}
          onmouseenter={isOutOfStock?'':"if(!this.disabled)this.style.background='#2C3B31'"}
          onmouseleave={isOutOfStock?'':"if(!this.disabled)this.style.background='#3F5147'"}
        >
          {isOutOfStock ? 'Agotado' : 'Añadir al carrito'}
        </button>

        <p style="font-size:11px;color:#9E9589;text-align:center;margin-top:10px;letter-spacing:0.05em;">
          ✦ Envío gratis a España a partir de 50 €
        </p>

        <!-- Accordions -->
        <div style="margin-top:24px;border-top:1px solid #DDD8C8;">
          {[
            { t:'Materiales y cuidados', c:'Fabricado artesanalmente con arcilla polimérica de alta calidad y resina UV hipoalergénica. Evita el contacto con agua, perfumes y productos químicos. Guárdala en lugar seco.' },
            { t:'Envíos y devoluciones', c:'Procesamos en 1–2 días hábiles. Entrega en 2–4 días hábiles en España. Devoluciones aceptadas en 14 días desde recepción en perfecto estado.' },
            { t:'Pequeñas variaciones artesanales', c:'Al ser hecha a mano, cada pieza puede presentar pequeñas variaciones en forma, color o textura. Esto es parte de su encanto — no hay dos piezas exactamente iguales.' },
          ].map(item => (
            <details style="border-bottom:1px solid #DDD8C8;">
              <summary style="display:flex;justify-content:space-between;align-items:center;padding:14px 0;cursor:pointer;font-size:13px;font-weight:700;color:#252525;letter-spacing:0.02em;list-style:none;">
                {item.t}
                <span style="font-size:18px;color:#9E9589;font-weight:300;transition:transform 0.2s;">+</span>
              </summary>
              <div style="padding:0 0 16px;">
                <p style="font-size:13px;color:#716A56;line-height:1.75;margin:0;">{item.c}</p>
              </div>
            </details>
          ))}
        </div>
      </div>
    </div>

    <!-- Related products -->
    {related.length > 0 && (
      <section style="margin-top:80px;padding-top:48px;border-top:1px solid #DDD8C8;">
        <div style="display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:32px;">
          <h2 style="font-family:'Trirong',Georgia,serif;font-weight:300;font-size:clamp(1.6rem,3vw,2.2rem);color:#252525;margin:0;">
            También te puede gustar
          </h2>
          <a href={product.categories ? `/tienda?categoria=${product.categories.slug}` : '/tienda'}
            style="font-size:12px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#716A56;text-decoration:none;" onmouseenter="this.style.color='#252525'" onmouseleave="this.style.color='#716A56'">
            Ver más →
          </a>
        </div>
        <div class="related-grid">
          {related.map((p: any) => <ProductCard product={p} />)}
        </div>
      </section>
    )}

  </div>

  <script>
    // Thumbnail gallery
    document.querySelectorAll('.thumb-btn').forEach((btn, _, all) => {
      btn.addEventListener('click', () => {
        const src = (btn as HTMLElement).dataset.src;
        const mainImg = document.getElementById('main-image') as HTMLImageElement;
        if (mainImg && src) {
          mainImg.style.opacity = '0';
          setTimeout(() => { mainImg.src = src; mainImg.style.opacity = '1'; }, 200);
        }
        all.forEach(b => (b as HTMLElement).style.borderColor = '#DDD8C8');
        (btn as HTMLElement).style.borderColor = '#3F5147';
      });
    });

    // Add to cart
    document.getElementById('add-to-cart')?.addEventListener('click', (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      if (btn.disabled) return;
      const productData = JSON.parse(btn.dataset.product || '{}');
      const cart = JSON.parse(localStorage.getItem('atlas_cart') || '[]');
      const existing = cart.find((i: any) => i.id === productData.id);
      if (existing) { if (existing.quantity < productData.stock) existing.quantity++; }
      else { cart.push({ ...productData, quantity: 1 }); }
      localStorage.setItem('atlas_cart', JSON.stringify(cart));
      window.dispatchEvent(new Event('cart-updated'));

      const orig = btn.textContent;
      btn.textContent = '✓ Añadido al carrito';
      btn.style.background = '#2C3B31';
      setTimeout(() => { btn.textContent = orig; btn.style.background = '#3F5147'; }, 2000);
    });

    // Accordion + icon
    document.querySelectorAll('details').forEach(d => {
      d.addEventListener('toggle', () => {
        const icon = d.querySelector('summary span') as HTMLElement;
        if (icon) icon.textContent = d.open ? '−' : '+';
      });
    });
  </script>

</StoreLayout>

<style>
  .product-layout {
    display: grid;
    grid-template-columns: 1fr 480px;
    gap: 64px;
    align-items: start;
  }
  .related-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  @media (max-width: 960px) {
    .product-layout { grid-template-columns: 1fr; gap: 40px; }
    .related-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  }
</style>

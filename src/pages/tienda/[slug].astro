---
import StoreLayout from '../../layouts/StoreLayout.astro';
import ProductCard from '../../components/storefront/ProductCard.astro';
import { getDb, IS_MOCK } from '../../lib/firebase-admin';
import { mockProducts } from '../../lib/mock-data';

const { slug } = Astro.params;

let product: any = null;
let related: any[] = [];

if (IS_MOCK) {
  product = mockProducts.find(p => p.slug === slug && p.active) || null;
  if (product) {
    related = mockProducts.filter(p => p.category_id === product.category_id && p.id !== product.id && p.active).slice(0, 4);
  }
} else {
  const db = getDb();
  const snap = await db.collection('products').where('slug', '==', slug).where('active', '==', true).limit(1).get();
  if (!snap.empty) {
    const doc = snap.docs[0];
    product = { id: doc.id, ...doc.data() };
    if (product.category_id) {
      const catDoc = await db.collection('categories').doc(product.category_id).get();
      if (catDoc.exists) product.categories = { id: catDoc.id, ...catDoc.data() };
    }
    const relSnap = await db.collection('products')
      .where('category_id', '==', product.category_id)
      .where('active', '==', true)
      .limit(5).get();
    related = relSnap.docs
      .map(d => ({ id: d.id, ...d.data() }))
      .filter((p: any) => p.id !== product.id)
      .slice(0, 4);
  }
}

if (!product) return Astro.redirect('/tienda');

const isOnSale = product.compare_at_price && product.compare_at_price > product.price;
const discount = isOnSale ? Math.round((1 - product.price / product.compare_at_price) * 100) : 0;
const isOutOfStock = product.stock === 0;
const isLowStock = product.stock > 0 && product.stock <= 3;
---

<StoreLayout title={`${product.name} — Atlas&You`} description={product.description}>

  <div class="max-w-7xl mx-auto px-6 py-10">

    <!-- Breadcrumb -->
    <nav class="flex items-center gap-2 text-[11px] font-medium tracking-wide uppercase text-stone-400 mb-10">
      <a href="/" class="hover:text-stone-700 transition-colors">Inicio</a>
      <span>/</span>
      <a href="/tienda" class="hover:text-stone-700 transition-colors">Tienda</a>
      {product.categories && (
        <>
          <span>/</span>
          <a href={`/tienda?categoria=${product.categories.slug}`} class="hover:text-stone-700 transition-colors">
            {product.categories.name}
          </a>
        </>
      )}
      <span>/</span>
      <span class="text-stone-600">{product.name}</span>
    </nav>

    <!-- Main product layout -->
    <div class="grid md:grid-cols-[1fr,480px] gap-12 lg:gap-20">

      <!-- Gallery -->
      <div class="space-y-3">
        <!-- Main image — 4:5 portrait -->
        <div class="overflow-hidden bg-stone-100" style="aspect-ratio:4/5;">
          <img
            id="main-image"
            src={product.images?.[0] || ''}
            alt={product.name}
            class="w-full h-full object-cover transition-opacity duration-300"
          />
        </div>

        <!-- Thumbnails -->
        {product.images && product.images.length > 1 && (
          <div class="grid grid-cols-4 gap-2">
            {product.images.map((img: string, i: number) => (
              <button
                class="overflow-hidden bg-stone-100 border-2 transition-all duration-150 thumbnail-btn"
                style={`aspect-ratio:1;border-color:${i === 0 ? '#1C1917' : 'transparent'};`}
                data-src={img}
                data-index={i}
              >
                <img src={img} alt={`${product.name} ${i + 1}`} class="w-full h-full object-cover" />
              </button>
            ))}
          </div>
        )}
      </div>

      <!-- Product info -->
      <div class="flex flex-col">

        <!-- Category + badges -->
        <div class="flex items-center gap-3 mb-3">
          {product.categories && (
            <a href={`/tienda?categoria=${product.categories.slug}`}
              class="text-[10px] font-semibold tracking-widest uppercase transition-colors"
              style="color:#92400E;">
              {product.categories.name}
            </a>
          )}
          {isOnSale && (
            <span class="text-[10px] font-semibold tracking-wider uppercase text-white px-2 py-0.5" style="background:#92400E;">
              -{discount}%
            </span>
          )}
        </div>

        <!-- Name -->
        <h1 class="font-serif text-stone-900 leading-tight mb-4"
            style="font-family:'Cormorant Garamond',Georgia,serif;font-weight:400;font-size:clamp(2rem,4vw,2.75rem);">
          {product.name}
        </h1>

        <!-- Price -->
        <div class="flex items-baseline gap-3 mb-2">
          <span class="text-2xl font-medium text-stone-900">{product.price.toFixed(2)}€</span>
          {isOnSale && (
            <span class="text-lg text-stone-400 line-through">{product.compare_at_price.toFixed(2)}€</span>
          )}
        </div>
        <p class="text-[11px] text-stone-400 tracking-wide mb-6">IVA incluido · Envío calculado al finalizar compra</p>

        <!-- Stock status -->
        {isOutOfStock && (
          <div class="flex items-center gap-2 mb-6 p-3 bg-stone-50 border border-stone-200">
            <span class="w-2 h-2 rounded-full bg-stone-400 flex-shrink-0"></span>
            <p class="text-sm text-stone-600 font-medium">Agotado — escríbenos para consultar disponibilidad</p>
          </div>
        )}
        {isLowStock && (
          <div class="flex items-center gap-2 mb-6 p-3 bg-amber-50 border border-amber-200">
            <span class="w-2 h-2 rounded-full flex-shrink-0" style="background:#D97706;"></span>
            <p class="text-sm font-medium" style="color:#92400E;">Solo quedan {product.stock} unidades</p>
          </div>
        )}

        <!-- Description -->
        <div class="text-stone-600 text-[15px] leading-relaxed mb-8 border-b border-stone-100 pb-8">
          <p>{product.description}</p>
        </div>

        <!-- Tags -->
        {product.tags && product.tags.length > 0 && (
          <div class="flex flex-wrap gap-1.5 mb-8">
            {product.tags.map((tag: string) => (
              <span class="text-[10px] font-medium tracking-widest uppercase text-stone-500 border border-stone-200 px-2.5 py-1">
                {tag}
              </span>
            ))}
          </div>
        )}

        <!-- Add to cart -->
        <button
          id="add-to-cart"
          disabled={isOutOfStock}
          data-product={JSON.stringify({ id: product.id, name: product.name, price: product.price, image: product.images?.[0] || '', slug: product.slug, stock: product.stock })}
          class="w-full py-4 text-[12px] font-medium tracking-widest uppercase text-white transition-all duration-200 disabled:cursor-not-allowed mb-3"
          style={isOutOfStock
            ? 'background:#D6D3D1;letter-spacing:0.1em;'
            : 'background:#1C1917;letter-spacing:0.1em;'}
          onmouseenter={isOutOfStock ? '' : "if(!this.disabled)this.style.background='#44403C'"}
          onmouseleave={isOutOfStock ? '' : "if(!this.disabled)this.style.background='#1C1917'"}
        >
          {isOutOfStock ? 'Agotado' : 'Añadir al carrito'}
        </button>

        <p class="text-[11px] text-stone-400 text-center tracking-wide mb-8">
          ✦ Envío gratis a España a partir de 50€
        </p>

        <!-- Accordion details -->
        <div class="space-y-0 border-t border-stone-200">
          <details class="group border-b border-stone-200">
            <summary class="flex justify-between items-center cursor-pointer py-4 text-sm font-medium text-stone-800 select-none">
              <span>Materiales y cuidados</span>
              <svg class="w-4 h-4 text-stone-400 transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
              </svg>
            </summary>
            <div class="pb-4 text-sm text-stone-500 leading-relaxed space-y-2">
              <p>Fabricado artesanalmente con arcilla polimérica de alta calidad y resina UV hipoalergénica.</p>
              <p>Para mantener tu joya en perfecto estado, evita el contacto prolongado con agua, perfumes y productos químicos. Guárdala en un lugar seco.</p>
            </div>
          </details>

          <details class="group border-b border-stone-200">
            <summary class="flex justify-between items-center cursor-pointer py-4 text-sm font-medium text-stone-800 select-none">
              <span>Envíos y devoluciones</span>
              <svg class="w-4 h-4 text-stone-400 transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
              </svg>
            </summary>
            <div class="pb-4 text-sm text-stone-500 leading-relaxed space-y-2">
              <p>Procesamos tu pedido en 1–2 días hábiles. Entrega en 2–4 días hábiles para España.</p>
              <p>Aceptamos devoluciones en 14 días desde la recepción si la pieza está en perfecto estado.</p>
            </div>
          </details>

          <details class="group border-b border-stone-200">
            <summary class="flex justify-between items-center cursor-pointer py-4 text-sm font-medium text-stone-800 select-none">
              <span>Hecho a mano — pequeñas variaciones</span>
              <svg class="w-4 h-4 text-stone-400 transition-transform duration-200 group-open:rotate-45" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
              </svg>
            </summary>
            <div class="pb-4 text-sm text-stone-500 leading-relaxed">
              <p>Al ser artesanal, cada pieza puede tener pequeñas variaciones en forma, color o textura. Esto es parte de su encanto — no hay dos piezas exactamente iguales.</p>
            </div>
          </details>
        </div>
      </div>
    </div>

    <!-- Related products -->
    {related.length > 0 && (
      <section class="mt-24 md:mt-32 pt-12" style="border-top:1px solid #E7E5E4;">
        <div class="flex items-end justify-between mb-10">
          <h2 class="font-serif text-3xl md:text-4xl text-stone-900"
              style="font-family:'Cormorant Garamond',Georgia,serif;font-weight:400;">
            También te puede gustar
          </h2>
          <a href={product.categories ? `/tienda?categoria=${product.categories.slug}` : '/tienda'}
            class="hidden md:inline-flex text-[11px] font-medium tracking-widest uppercase text-stone-400 hover:text-stone-900 transition-colors items-center gap-1.5">
            Ver más <span>→</span>
          </a>
        </div>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-x-4 gap-y-10">
          {related.map((p: any) => <ProductCard product={p} />)}
        </div>
      </section>
    )}

  </div>

  <script>
    // Thumbnail gallery
    document.querySelectorAll('.thumbnail-btn').forEach((btn, _, all) => {
      btn.addEventListener('click', () => {
        const src = (btn as HTMLElement).dataset.src;
        const mainImg = document.getElementById('main-image') as HTMLImageElement;
        if (mainImg && src) {
          mainImg.style.opacity = '0';
          setTimeout(() => { mainImg.src = src; mainImg.style.opacity = '1'; }, 150);
        }
        all.forEach(b => (b as HTMLElement).style.borderColor = 'transparent');
        (btn as HTMLElement).style.borderColor = '#1C1917';
      });
    });

    // Add to cart
    document.getElementById('add-to-cart')?.addEventListener('click', (e) => {
      const btn = e.currentTarget as HTMLButtonElement;
      if (btn.disabled) return;
      const productData = JSON.parse(btn.dataset.product || '{}');
      const cart = JSON.parse(localStorage.getItem('atlas_cart') || '[]');
      const existing = cart.find((item: any) => item.id === productData.id);
      if (existing) { if (existing.quantity < productData.stock) existing.quantity++; }
      else { cart.push({ ...productData, quantity: 1 }); }
      localStorage.setItem('atlas_cart', JSON.stringify(cart));
      window.dispatchEvent(new Event('cart-updated'));

      const original = btn.textContent;
      btn.textContent = '✓ Añadido al carrito';
      btn.style.background = '#166534';
      setTimeout(() => {
        btn.textContent = original;
        btn.style.background = '#1C1917';
      }, 2000);
    });
  </script>

</StoreLayout>

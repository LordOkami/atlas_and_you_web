---
import StoreLayout from '../../layouts/StoreLayout.astro';
import ProductCard from '../../components/storefront/ProductCard.astro';
import { getDb, IS_MOCK } from '../../lib/firebase-admin';
import { mockProducts, mockCategories } from '../../lib/mock-data';

const categoria = Astro.url.searchParams.get('categoria');
const busqueda = Astro.url.searchParams.get('q');

let products: any[] = [];
let categories: any[] = [];

if (IS_MOCK) {
  categories = mockCategories;
  products = mockProducts.filter(p => p.active);
  if (categoria) {
    const cat = mockCategories.find(c => c.slug === categoria);
    if (cat) products = products.filter(p => p.category_id === cat.id);
  }
  if (busqueda) products = products.filter(p => p.name.toLowerCase().includes(busqueda.toLowerCase()));
} else {
  const db = getDb();
  const catSnap = await db.collection('categories').where('active','==',true).orderBy('position').get();
  categories = catSnap.docs.map(d => ({ id: d.id, ...d.data() }));
  let query: any = db.collection('products').where('active','==',true);
  if (categoria) {
    const cat = categories.find((c: any) => c.slug === categoria);
    if (cat) query = query.where('category_id','==',cat.id);
  }
  const prodSnap = await query.orderBy('created_at','desc').get();
  products = prodSnap.docs.map((d: any) => ({ id: d.id, ...d.data() }));
  if (busqueda) products = products.filter(p => p.name.toLowerCase().includes(busqueda.toLowerCase()));
}

const activeCategory = categories.find((c: any) => c.slug === categoria);
const pageTitle = activeCategory ? `${activeCategory.name} — Atlas&You` : 'Toda la colección — Atlas&You';
---

<StoreLayout title={pageTitle}>

  <!-- Page header (white strip) -->
  <div style="background:#FFFFFF;border-bottom:1px solid #DDD8C8;">
    <div style="max-width:1440px;margin:0 auto;padding:40px 32px 32px;">

      <!-- Breadcrumb -->
      <nav style="display:flex;align-items:center;gap:8px;font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#9E9589;margin-bottom:20px;">
        <a href="/" style="color:#9E9589;text-decoration:none;" onmouseenter="this.style.color='#252525'" onmouseleave="this.style.color='#9E9589'">Inicio</a>
        <span style="color:#DDD8C8;">/</span>
        <span style="color:#252525;">{activeCategory ? activeCategory.name : 'Tienda'}</span>
      </nav>

      <!-- Title row -->
      <div style="display:flex;flex-wrap:wrap;align-items:flex-end;justify-content:space-between;gap:16px;margin-bottom:24px;">
        <div>
          <h1 style="font-family:'Trirong',Georgia,serif;font-weight:300;font-size:clamp(1.8rem,4vw,2.8rem);color:#252525;margin:0 0 4px;">
            {activeCategory ? activeCategory.name : 'Toda la colección'}
          </h1>
          <p style="font-size:12px;color:#9E9589;">{products.length} {products.length === 1 ? 'pieza' : 'piezas'}</p>
        </div>

        <!-- Search -->
        <form method="get" action="/tienda" style="position:relative;width:260px;">
          {categoria && <input type="hidden" name="categoria" value={categoria} />}
          <svg style="position:absolute;left:12px;top:50%;transform:translateY(-50%);color:#9E9589;" width="15" height="15" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
          </svg>
          <input
            type="text" name="q" value={busqueda || ''}
            placeholder="Buscar..."
            style="width:100%;padding:10px 12px 10px 36px;font-size:13px;border:1px solid #DDD8C8;background:#FAFAF8;outline:none;font-family:'Quattrocento Sans',sans-serif;box-sizing:border-box;"
            onfocus="this.style.borderColor='#3F5147'"
            onblur="this.style.borderColor='#DDD8C8'"
          />
        </form>
      </div>

      <!-- Category pills -->
      <div style="display:flex;flex-wrap:wrap;gap:8px;">
        <a href="/tienda" style={`display:inline-flex;align-items:center;padding:7px 16px;font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;transition:all 0.15s;${!categoria ? 'background:#252525;color:#FAFAF8;border:1px solid #252525;' : 'background:transparent;color:#716A56;border:1px solid #DDD8C8;'}`}>
          Todos
        </a>
        {categories.map((cat: any) => (
          <a href={`/tienda?categoria=${cat.slug}`}
            style={`display:inline-flex;align-items:center;padding:7px 16px;font-size:11px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;text-decoration:none;transition:all 0.15s;${categoria === cat.slug ? 'background:#252525;color:#FAFAF8;border:1px solid #252525;' : 'background:transparent;color:#716A56;border:1px solid #DDD8C8;'}`}
            onmouseenter={`if(this.style.background!='rgb(37, 37, 37)')this.style.borderColor='#716A56'`}
            onmouseleave={`if(this.style.background!='rgb(37, 37, 37)')this.style.borderColor='#DDD8C8'`}
          >
            {cat.name}
          </a>
        ))}
      </div>
    </div>
  </div>

  <!-- Product grid -->
  <div style="max-width:1440px;margin:0 auto;padding:48px 32px 80px;">
    {products.length > 0 ? (
      <div class="catalog-grid">
        {products.map((product: any) => <ProductCard product={product} />)}
      </div>
    ) : (
      <div style="text-align:center;padding:100px 32px;">
        <p style="font-family:'Trirong',Georgia,serif;font-weight:300;font-size:1.8rem;color:#716A56;margin-bottom:8px;">Sin resultados</p>
        <p style="font-size:13px;color:#9E9589;margin-bottom:24px;">Prueba con otra categoría o término</p>
        <a href="/tienda" style="font-size:12px;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#3F5147;text-decoration:none;border-bottom:1px solid #3F5147;padding-bottom:2px;">Ver toda la colección</a>
      </div>
    )}
  </div>

</StoreLayout>

<style>
  .catalog-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  @media (max-width: 1100px) {
    .catalog-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (max-width: 700px) {
    .catalog-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
  }
</style>
